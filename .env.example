# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------

# Chave secreta — em produção gerar com:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 1 =
DJANGO_DEBUG=

# Hosts permitidos — só necessário quando DJANGO_DEBUG=
# Separados por vírgula, sem espaços
# Exemplo: DJANGO_ALLOWED_HOSTS=
DJANGO_ALLOWED_HOSTS=

# Path do SQLite: relativo =
# Desenvolvimento: db.sqlite3
# Docker:          /app/db/db.sqlite3  (dentro do volume montado)
DJANGO_DB_NAME=

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------

# Em desenvolvimento local: 127.0.0.1
# Em Docker: nome do serviço definido no docker-compose.yml (redis)
REDIS_HOST=
REDIS_PORT=

# ---------------------------------------------------------------------------
# Hardware (Arduino Due)
# ---------------------------------------------------------------------------

# 0 =
# 1 =
USE_REAL_HARDWARE=

# Porta serial do Arduino Due (ignorada se USE_REAL_HARDWARE=
ARDUINO_PORT=
ARDUINO_BAUD=
ARDUINO_TIMEOUT=

# ---------------------------------------------------------------------------
# Email (só necessário quando se implementar reset de password)
# ---------------------------------------------------------------------------

# console =
# smtp    =
DJANGO_EMAIL_BACKEND=

# Preencher apenas quando DJANGO_EMAIL_BACKEND=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=

